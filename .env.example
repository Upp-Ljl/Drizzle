# =============================================================
# 梗气象台 — .env.example
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. Never commit it.
# =============================================================

# ---- Supabase (required) ----
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-publishable-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key-server-only

# ---- Database direct connection (for drizzle migrations) ----
# From: Supabase Dashboard → Project Settings → Database → Connection string (URI mode)
# Use the "Connection pooling" string for migrations to avoid IPv6 issues.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# ---- App config ----
# Vercel injects VERCEL_URL automatically; for local dev set:
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Cron secret (Vercel Cron uses this header to authorize) ----
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=PUT-A-64-CHAR-HEX-STRING-HERE

# ---- Demo mode ----
# When true, /demo-accelerate route is mounted and POST /api/dev/accelerate works.
# Set to false in production.
DEMO_MODE=true
